//Some Test Stuff with the Parents
script PlayersHouse_1F_Text_Mom_One {
	lock
	faceplayer
	setspeaker(SP_NAME_MOM)
	//Test Multi Choice Message
	message(format("Hello sweetie, How are you doing?"))
	waitmessage
	multichoice(25,5, MULTI_TEST ,1)
	closemessage
	if(var(VAR_RESULT) == 0){
		setspeaker(SP_NAME_MOM)
		msgbox(format("Thats good to hear"), MSGBOX_NPC)
	}
	elif(var(VAR_RESULT) == 1){
		setspeaker(SP_NAME_MOM)
		msgbox(format("Thats Ok to hear"), MSGBOX_NPC)
	}
	elif(var(VAR_RESULT) == 2){
		setspeaker(SP_NAME_MOM)
		msgbox(format("I'm sorry sweetie"), MSGBOX_NPC)
	}

	//Test changing text based on state
	if(var(VAR_COLUMBUS_INTRO_STATE) > 0)
	{
		switch (var(VAR_COLUMBUS_INTRO_STATE)){
			case 1:
				msgbox(format("Var 1 test! Whatever that means"), MSGBOX_NPC)
			case 2:
				msgbox(format("Var 2 test! Whatever that means"), MSGBOX_NPC)
			default:
				msgbox("Error.")
		}
	}

	applymovement(Mom, moves(face_original_direction))

	release
}

script PlayersHouse_1F_Text_Dad_One {
	lock
	faceplayer
	setspeaker("Dad")
	//Testing changing text and state
	if(var(VAR_COLUMBUS_INTRO_STATE) != 2)
	{
	msgbox(format("Hey there kiddo. Seting Var to 2"))
	setvar(VAR_COLUMBUS_INTRO_STATE, 2)
	}
	else
	{
	msgbox(format("Hey there kiddo. Seting Var to 1"))
	setvar(VAR_COLUMBUS_INTRO_STATE, 1)
	}
	applymovement(Dad, moves(face_original_direction))
	releaseall
}