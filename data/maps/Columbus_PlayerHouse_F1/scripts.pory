mapscripts Columbus_PlayerHouse_F1_MapScripts {}




script PlayersHouse_1F_Text_Mom_Text_Real {
	lock
	faceplayer
	if(var(VAR_COLUMBUS_INTRO_STATE) == 1)
	{
	setspeaker(SP_NAME_MOM)
	msgbox(format("Hi sweetie, have fun at the library today, and make sure to stay close to your sister ok? Also um, I know you two can get on each other's nerves a bit but can you please go a little easy on her today? I'm not sure exactly what happened but I think her and Terry got in a bit of a fight."), MSGBOX_NPC)
	applymovement(Mom, moves(face_original_direction))
	release
	}
	else {
		msgbox(format("Hi sweetie."), MSGBOX_NPC)

	}


}

script PlayersHouse_1F_Text_Dad_Text_Real {
	lock
	faceplayer
	if(var(VAR_COLUMBUS_INTRO_STATE) == 1)
	{
	setspeaker(SP_NAME_MOM)
	msgbox(format("Hey kiddo, shouldn't you be on your way to the library by now? That lecture thing should be starting soon right?"), MSGBOX_NPC)
	applymovement(Mom, moves(face_original_direction))
	release
	}
	else {
		msgbox(format("Hey kiddo."), MSGBOX_NPC)

	}


}


